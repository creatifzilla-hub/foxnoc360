# ──────────────────────────────────────────────
# ISP SLA Monitoring Platform — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values before starting the services.

# ── Project ────────────────────────────────────
PROJECT_NAME="ISP SLA Monitor"
ENVIRONMENT=development
DEBUG=True

# ── Database ───────────────────────────────────
# PostgreSQL (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/isp_monitor

# ── Redis ──────────────────────────────────────
# Used for RQ distributed job queue
REDIS_URL=redis://localhost:6379/0

# ── Authentication ─────────────────────────────
SECRET_KEY=change-me-before-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ───────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── SMTP Email Alerts ──────────────────────────
# Any SMTP provider (Mailtrap for dev, Gmail, Postmark, etc.)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your_smtp_user
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=alerts@isp-monitor.local

# ── Twilio WhatsApp Alerts ──────────────────────
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Twilio Sandbox number (Prod: your verified Twilio WhatsApp number)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

